# NETKIT_ARCH => CMSIS-DSP ARM_MATH_* flags (see arm_math.h).
# Empty NETKIT_ARCH => desktop / CPU (no core-specific ARM_MATH_* defines).

NETKIT_ARCH ?=
NETKIT_ARCH_UPPER := $(shell printf '%s' '$(NETKIT_ARCH)' | tr '[:lower:]' '[:upper:]')
NETKIT_ARCH_UPPER := $(subst CORTEX-,,$(NETKIT_ARCH_UPPER))
NETKIT_ARCH_UPPER := $(subst CORTEX,,$(NETKIT_ARCH_UPPER))

NETKIT_ARCH_CFLAGS :=

ifneq ($(NETKIT_ARCH),)
  ifeq ($(NETKIT_ARCH_UPPER),CM0)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM0
  else ifeq ($(NETKIT_ARCH_UPPER),M0)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM0
  else ifeq ($(NETKIT_ARCH_UPPER),CM0PLUS)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM0PLUS
  else ifeq ($(NETKIT_ARCH_UPPER),M0PLUS)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM0PLUS
  else ifeq ($(NETKIT_ARCH_UPPER),CM0+)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM0PLUS
  else ifeq ($(NETKIT_ARCH_UPPER),CM3)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM3
  else ifeq ($(NETKIT_ARCH_UPPER),M3)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM3
  else ifeq ($(NETKIT_ARCH_UPPER),CM4)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM4
  else ifeq ($(NETKIT_ARCH_UPPER),M4)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM4
  else ifeq ($(NETKIT_ARCH_UPPER),CM7)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM7
  else ifeq ($(NETKIT_ARCH_UPPER),M7)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_CM7
  else ifeq ($(NETKIT_ARCH_UPPER),M23)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_ARMV8MBL
  else ifeq ($(NETKIT_ARCH_UPPER),CM23)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_ARMV8MBL
  else ifeq ($(NETKIT_ARCH_UPPER),M33)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_ARMV8MML -D__DSP_PRESENT=1
  else ifeq ($(NETKIT_ARCH_UPPER),CM33)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_ARMV8MML -D__DSP_PRESENT=1
  else ifeq ($(NETKIT_ARCH_UPPER),M55)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_M55 -DARM_MATH_MVEF -DARM_MATH_MVEI
  else ifeq ($(NETKIT_ARCH_UPPER),CM55)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_M55 -DARM_MATH_MVEF -DARM_MATH_MVEI
  else ifeq ($(NETKIT_ARCH_UPPER),M85)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_M85 -DARM_MATH_MVEF -DARM_MATH_MVEI
  else ifeq ($(NETKIT_ARCH_UPPER),CM85)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_M85 -DARM_MATH_MVEF -DARM_MATH_MVEI
  else ifeq ($(NETKIT_ARCH_UPPER),A32)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_A32
  else ifeq ($(NETKIT_ARCH_UPPER),MPU)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_A32
  else ifeq ($(NETKIT_ARCH_UPPER),NEON)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_NEON
  else ifeq ($(NETKIT_ARCH_UPPER),CORTEXA)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_NEON
  else ifeq ($(NETKIT_ARCH_UPPER),A64)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_NEON
  else
    $(error Unknown NETKIT_ARCH '$(NETKIT_ARCH)'. Use CM0, CM0PLUS, CM3, CM4, CM7, M23, M33, M55, M85, A32, or NEON; leave unset for desktop.)
  endif
endif

# Desktop host builds use CMSIS-DSP's portable GNUC_PYTHON path.
ifeq ($(NETKIT_ARCH),)
  ifeq ($(NETKIT_TARGET),cpu)
    NETKIT_ARCH_CFLAGS += -D__GNUC_PYTHON__
  endif
  ifeq ($(NETKIT_CMSIS_DSP),1)
    NETKIT_ARCH_CFLAGS += -DARM_MATH_LOOPUNROLL
  endif
endif

# Embedded firmware: loop unrolling (CMSIS-DSP 1.10+ defaults off) + CMSIS-Core include.
ifneq ($(NETKIT_ARCH),)
  NETKIT_ARCH_CFLAGS += -DARM_MATH_LOOPUNROLL
  CMSISCORE_DIR ?= third_party/CMSIS-Core/Include
  ifneq ($(wildcard $(CMSISCORE_DIR)),)
    NETKIT_ARCH_CFLAGS += -I$(CMSISCORE_DIR)
  endif
endif

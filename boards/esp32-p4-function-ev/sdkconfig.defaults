# ESP32-P4-Function-EV-Board: USB-UART bridge (CH34x), not USB-Serial-JTAG.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=n
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y

# Board flash is typically 16MB+ (header may report 16MB); leave room for app.
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

CONFIG_COMPILER_OPTIMIZATION_PERF=y
# Main stack: ParsedModel is static on MCU (see nk_loader.cpp). Keep modest
# headroom for P4 FPU frames / plan build; do not size for ~27 KiB catalog.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384
CONFIG_FREERTOS_HZ=1000
# Long int8 benches starve IDLE; disable task WDT for firmware A/B runs.
CONFIG_ESP_TASK_WDT_EN=n
